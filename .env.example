# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────
POSTGRES_USER=finverse
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=finverse_db
DATABASE_URL=postgresql://finverse:change_me_in_production@localhost:5432/finverse_db

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASSWORD=redis_secret

# ─── Auth / JWT ────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI Services ───────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=internal_api_key_change_me
OPENAI_API_KEY=sk-your-openai-key-here

# ─── External Market Data ──────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_key

# ─── Email (optional) ──────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@finverse.ai
SMTP_PASS=smtp_password

# ─── Client (Vite) ─────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api/v1
VITE_AI_URL=http://localhost:8000/api/v1
VITE_APP_NAME=FinVerse AI
